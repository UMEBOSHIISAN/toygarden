{
  "name": "umeplay",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "UMEBOSHI 遊び枠プラットフォーム — apps/ を core-* 部品で組む modular monorepo",
  "workspaces": [
    "contracts",
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm test",
    "build:aquarium": "esbuild apps/ascii-aquarium/src/cli.ts --bundle --platform=node --format=esm --outfile=dist/aquarium.mjs",
    "aquarium": "npm run build:aquarium && node dist/aquarium.mjs",
    "build:symphony": "esbuild apps/commit-symphony/src/cli.ts --bundle --platform=node --format=esm --outfile=dist/symphony.mjs",
    "symphony": "npm run build:symphony && node dist/symphony.mjs",
    "build:replay": "esbuild apps/git-replay/src/cli.ts --bundle --platform=node --format=esm --outfile=dist/replay.mjs",
    "replay": "npm run build:replay && node dist/replay.mjs",
    "build:loom": "esbuild apps/event-loom/src/cli.ts --bundle --platform=node --format=esm --outfile=dist/loom.mjs",
    "loom": "npm run build:loom && node dist/loom.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
